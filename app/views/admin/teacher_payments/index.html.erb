<h1 class="mb-4">Pagos a Profesores</h1>

<div class="row">
  <!-- Contenido principal -->
  <div class="col-md-9">
    <div class="card">
      <div class="card-body">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th>Profesor</th>
              <th>Mes</th>
              <th>Total Matrículas Mensuales</th>
              <th>Monto a Pagar (42.5%)</th>
              <th>Estado</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% @payments_by_teacher_and_month.each do |teacher, payments_by_month| %>
              <% payments_by_month.each do |month, enrollments| %>
                <% total_enrollment_fee = enrollments.sum(&:total_tuition_fee) %>
                <% payment_amount = total_enrollment_fee * 0.425 %>
                <% teacher_payment = TeacherPayment.find_by(teacher_id: teacher.id, period_start: month.beginning_of_month, period_end: month.end_of_month) %>
                <tr>
                  <td><%= teacher.user.name %></td>
                  <td><%= l(month, format: '%B %Y') %></td>
                  <td><%= number_to_currency(total_enrollment_fee) %></td>
                  <td><%= number_to_currency(payment_amount) %></td>
                  <td>
                    <%= form_tag toggle_status_admin_teacher_payment_path(teacher), method: :patch, style: "margin: 0;" do %>
                      <%= hidden_field_tag :month, month.strftime('%Y-%m-%d') %>
                      <%= hidden_field_tag :filter_month, @selected_month&.strftime('%Y-%m-%d') %>
                      <%= hidden_field_tag :filter_status, @selected_status %>
                      <%= select_tag :new_status,
                          options_for_select(
                            [['No Pagado', 'pending'], ['Pagado', 'paid']],
                            teacher_payment&.status || 'pending'
                          ),
                          class: "form-select form-select-sm",
                          style: "width: auto; min-width: 120px;",
                          onchange: "this.form.submit();" %>
                    <% end %>
                  </td>
                  <td>
                    <%= link_to 'Ver Matrículas', admin_teacher_payment_path(teacher, month: month.strftime('%Y-%m-%d')), class: 'btn btn-sm btn-primary' %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>

        <% if @payments_by_teacher_and_month.empty? || @payments_by_teacher_and_month.values.all?(&:empty?) %>
          <div class="alert alert-info mt-3 mb-0">
            No hay pagos registrados con los filtros seleccionados.
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Filtros lateral derecho -->
  <div class="col-md-3">
    <div class="card">
      <div class="card-header">
        <strong>Filtros</strong>
      </div>
      <div class="card-body">
        <%= form_tag(admin_teacher_payments_path, method: :get) do %>
          <div class="mb-3">
            <label class="form-label">Mes</label>
            <%= select_tag :month,
                options_for_select(
                  @available_months.map { |m| [l(m, format: '%B %Y'), m.strftime('%Y-%m-%d')] },
                  @selected_month&.strftime('%Y-%m-%d')
                ),
                include_blank: 'Todos los meses',
                class: 'form-select' %>
          </div>

          <div class="mb-3">
            <label class="form-label">Estado</label>
            <%= select_tag :status,
                options_for_select(
                  [['Pagado', 'paid'], ['No Pagado', 'pending']],
                  @selected_status
                ),
                include_blank: 'Todos',
                class: 'form-select' %>
          </div>

          <div class="d-grid gap-2">
            <%= submit_tag 'Aplicar Filtros', class: 'btn btn-primary' %>
            <% if @selected_month || @selected_status %>
              <%= link_to 'Limpiar Filtros', admin_teacher_payments_path, class: 'btn btn-outline-secondary' %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
