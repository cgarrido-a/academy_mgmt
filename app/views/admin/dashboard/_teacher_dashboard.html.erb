<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
  <h1 style="color: #2c3e50;">Mi Dashboard</h1>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <h3>Mis Secciones</h3>
    <div class="number"><%= @total_sections %></div>
  </div>

  <div class="stat-card">
    <h3>Mis Alumnos</h3>
    <div class="number"><%= @total_students %></div>
  </div>

  <div class="stat-card">
    <h3>Asistencia del mes</h3>
    <% if @month_attendance_rate %>
      <div class="number" style="color: <%= @month_attendance_rate >= 75 ? '#27ae60' : @month_attendance_rate >= 50 ? '#f39c12' : '#e74c3c' %>;">
        <%= @month_attendance_rate %>%
      </div>
    <% else %>
      <div class="number" style="color: #bdc3c7;">--</div>
    <% end %>
    <span style="font-size: 0.8rem; color: #7f8c8d;"><%= @month_present %> presentes / <%= @month_absent %> ausentes</span>
  </div>

  <div class="stat-card">
    <h3>Sin registrar</h3>
    <div class="number" style="color: <%= @month_pending > 0 ? '#f39c12' : '#27ae60' %>;"><%= @month_pending %></div>
    <span style="font-size: 0.8rem; color: #7f8c8d;">clases por registrar</span>
  </div>
</div>

<% if @pending_dates.any? %>
  <div class="card" style="border-left: 4px solid #f39c12; margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; color: #f39c12; margin-bottom: 0.75rem;">Asistencia pendiente</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      <% @pending_dates.first(8).each do |p| %>
        <%= link_to admin_section_path(p[:section], date: p[:date]),
            style: "text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; background: #fff8e1; border: 1px solid #ffe082; padding: 0.5rem 0.75rem; border-radius: 6px; color: #2c3e50; font-size: 0.85rem; transition: background 0.2s;",
            onmouseover: "this.style.background='#fff3cd'",
            onmouseout: "this.style.background='#fff8e1'" do %>
          <strong><%= p[:section].course.title %></strong>
          <span style="color: #7f8c8d;"><%= I18n.l(p[:date], format: '%a %d/%m') %></span>
          <span style="background: #f39c12; color: white; padding: 0.15rem 0.5rem; border-radius: 10px; font-size: 0.75rem;"><%= p[:count] %></span>
        <% end %>
      <% end %>
      <% if @pending_dates.size > 8 %>
        <span style="align-self: center; color: #7f8c8d; font-size: 0.85rem;">y <%= @pending_dates.size - 8 %> mas...</span>
      <% end %>
    </div>
  </div>
<% end %>

<% if @section_attendance.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">Asistencia por seccion - <%= I18n.l(@calendar_date, format: '%B %Y').capitalize %></h2>
    <table>
      <thead>
        <tr>
          <th>Seccion</th>
          <th>Dia</th>
          <th style="text-align: center;">Presentes</th>
          <th style="text-align: center;">Ausentes</th>
          <th style="text-align: center;">Pendientes</th>
          <th style="text-align: center;">Asistencia</th>
        </tr>
      </thead>
      <tbody>
        <% @section_attendance.each do |sa| %>
          <tr>
            <td>
              <%= link_to sa[:section].course.title, admin_section_path(sa[:section]), style: "color: #3498db; text-decoration: none; font-weight: 500;" %>
            </td>
            <td style="color: #7f8c8d;"><%= sa[:section].weekday %> &middot; <%= sa[:section].formatted_schedule %></td>
            <td style="text-align: center; color: #27ae60; font-weight: 600;"><%= sa[:present] %></td>
            <td style="text-align: center; color: #e74c3c; font-weight: 600;"><%= sa[:absent] %></td>
            <td style="text-align: center; color: #f39c12; font-weight: 600;"><%= sa[:total] - sa[:present] - sa[:absent] %></td>
            <td style="text-align: center;">
              <% if sa[:rate] %>
                <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
                  <div style="width: 60px; height: 8px; background: #eee; border-radius: 4px; overflow: hidden;">
                    <div style="width: <%= sa[:rate] %>%; height: 100%; background: <%= sa[:rate] >= 75 ? '#27ae60' : sa[:rate] >= 50 ? '#f39c12' : '#e74c3c' %>; border-radius: 4px;"></div>
                  </div>
                  <span style="font-weight: 600; font-size: 0.9rem; color: <%= sa[:rate] >= 75 ? '#27ae60' : sa[:rate] >= 50 ? '#f39c12' : '#e74c3c' %>;"><%= sa[:rate] %>%</span>
                </div>
              <% else %>
                <span style="color: #bdc3c7;">--</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div class="card">
  <div class="calendar-header">
    <h2>Mi Calendario</h2>
    <div class="calendar-nav">
      <%= link_to admin_root_path(month: @prev_month.month, year: @prev_month.year, course_id: @selected_course_id), class: "btn btn-secondary" do %>
        &larr; <%= I18n.l(@prev_month, format: '%B') %>
      <% end %>
      <span class="calendar-current-month">
        <%= I18n.l(@calendar_date, format: '%B %Y').capitalize %>
      </span>
      <%= link_to admin_root_path(month: @next_month.month, year: @next_month.year, course_id: @selected_course_id), class: "btn btn-secondary" do %>
        <%= I18n.l(@next_month, format: '%B') %> &rarr;
      <% end %>
    </div>
  </div>

  <div class="course-filters">
    <span class="filter-label">Filtrar por curso:</span>
    <%= link_to "Todos", admin_root_path(month: @month, year: @year), class: "filter-btn #{@selected_course_id.nil? ? 'active' : ''}" %>
    <% @teacher_courses.each do |course| %>
      <%= link_to course.title, admin_root_path(month: @month, year: @year, course_id: course.id), class: "filter-btn #{@selected_course_id == course.id ? 'active' : ''}" %>
    <% end %>
  </div>

  <div class="monthly-calendar">
    <div class="calendar-weekdays">
      <% %w[Lun Mar Mie Jue Vie].each do |day| %>
        <div class="weekday-header"><%= day %></div>
      <% end %>
      <% %w[Sab Dom].each do |day| %>
        <div class="weekday-header weekend"><%= day %></div>
      <% end %>
    </div>

    <div class="calendar-body">
      <% today = Date.current %>
      <% @calendar_weeks.each do |week| %>
        <% week.each do |day| %>
          <%
            cell_classes = []
            cell_classes << 'other-month' unless day[:in_month]
            cell_classes << 'today'       if day[:is_today]
            cell_classes << 'weekend'     if [0, 6].include?(day[:date].wday)
          %>
          <div class="calendar-cell <%= cell_classes.join(' ') %>">
            <div class="cell-date"><%= day[:date].day %></div>
            <div class="cell-sections">
              <% day[:sections].each do |section| %>
                <%
                  student_count = @students_by_section_date[[section.id, day[:date]]] || 0
                  next if student_count.zero? && !day[:is_today]
                  status = @attendance_status_by_section_date[[section.id, day[:date]]]
                  marked  = status ? status[:present] + status[:absent] : 0
                  total   = status ? status[:total] : student_count

                  state =
                    if total.zero?
                      'empty'
                    elsif day[:is_today]
                      'today'
                    elsif day[:date] > today
                      'upcoming'
                    elsif marked == total && total.positive?
                      'done'
                    elsif day[:date] <= today
                      'pending'
                    else
                      'upcoming'
                    end

                  dot_class = case state
                              when 'done'     then 'done'
                              when 'pending'  then 'pending'
                              else 'upcoming'
                              end
                %>
                <%= link_to admin_section_path(section, date: day[:date]),
                      class: "calendar-section state-#{state}",
                      title: state == 'done'    ? "Asistencia completa (#{status[:present]}/#{total})" :
                             state == 'pending' ? "Pendiente de marcar (#{total - marked} sin asistencia)" :
                             "#{total} alumnos" do %>
                  <span class="section-name"><%= truncate(section.course.title, length: 18) %></span>
                  <span class="section-schedule"><%= section.formatted_schedule %></span>
                  <span class="section-students">
                    <span class="att-dot <%= dot_class %>"></span>
                    <% if state == 'done' %>
                      ✓ <%= status[:present] %>/<%= total %>
                    <% elsif state == 'pending' %>
                      <%= total - marked %>/<%= total %> sin marcar
                    <% else %>
                      <%= total %> alumno<%= 's' if total != 1 %>
                    <% end %>
                  </span>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="calendar-legend-row">
    <span class="legend-item"><span class="legend-swatch state-today"></span> Hoy</span>
    <span class="legend-item"><span class="legend-swatch state-upcoming"></span> Próximas</span>
    <span class="legend-item"><span class="legend-swatch state-pending"></span> Pendiente de marcar</span>
    <span class="legend-item"><span class="legend-swatch state-done"></span> Asistencia completa</span>
  </div>
</div>
