<%= form_with model: [:admin, section], local: true do |f| %>
  <% if section.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(section.errors.count, "error") %> impidieron guardar esta sección:</h3>
      <ul>
        <% section.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :course_id, "Curso" %>
    <%= f.select :course_id, options_from_collection_for_select(courses, :id, :title, section.course_id), { prompt: "Seleccione un curso" }, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :teacher_id, "Profesor" %>
    <%= f.select :teacher_id, options_from_collection_for_select(teachers, :id, ->(t) { t.user.name }, section.teacher_id), { prompt: "Seleccione un profesor" }, required: true %>
  </div>

  <div class="form-group">
    <label>Horarios</label>
    <div id="schedule-entries">
      <% if section.schedule.present? && section.schedule.any? %>
        <% section.schedule.each_with_index do |entry, index| %>
          <div class="schedule-entry" data-index="<%= index %>">
            <select name="section[schedule][][day]" required>
              <option value="">Seleccione día</option>
              <option value="monday" <%= 'selected' if entry['day'] == 'monday' %>>Lunes</option>
              <option value="tuesday" <%= 'selected' if entry['day'] == 'tuesday' %>>Martes</option>
              <option value="wednesday" <%= 'selected' if entry['day'] == 'wednesday' %>>Miércoles</option>
              <option value="thursday" <%= 'selected' if entry['day'] == 'thursday' %>>Jueves</option>
              <option value="friday" <%= 'selected' if entry['day'] == 'friday' %>>Viernes</option>
              <option value="saturday" <%= 'selected' if entry['day'] == 'saturday' %>>Sábado</option>
              <option value="sunday" <%= 'selected' if entry['day'] == 'sunday' %>>Domingo</option>
            </select>
            <input type="time" name="section[schedule][][start_time]" value="<%= entry['start_time'] %>" required placeholder="Hora inicio">
            <input type="time" name="section[schedule][][end_time]" value="<%= entry['end_time'] %>" required placeholder="Hora fin">
            <button type="button" class="btn btn-danger btn-sm" onclick="removeScheduleEntry(this)">Eliminar</button>
          </div>
        <% end %>
      <% else %>
        <div class="schedule-entry" data-index="0">
          <select name="section[schedule][][day]" required>
            <option value="">Seleccione día</option>
            <option value="monday">Lunes</option>
            <option value="tuesday">Martes</option>
            <option value="wednesday">Miércoles</option>
            <option value="thursday">Jueves</option>
            <option value="friday">Viernes</option>
            <option value="saturday">Sábado</option>
            <option value="sunday">Domingo</option>
          </select>
          <input type="time" name="section[schedule][][start_time]" required placeholder="Hora inicio">
          <input type="time" name="section[schedule][][end_time]" required placeholder="Hora fin">
          <button type="button" class="btn btn-danger btn-sm" onclick="removeScheduleEntry(this)">Eliminar</button>
        </div>
      <% end %>
    </div>
    <button type="button" class="btn btn-secondary btn-sm" onclick="addScheduleEntry()" style="margin-top: 10px;">Agregar Horario</button>
  </div>

  <script>
    let scheduleIndex = <%= section.schedule&.length || 1 %>;

    function addScheduleEntry() {
      const container = document.getElementById('schedule-entries');
      const entry = document.createElement('div');
      entry.className = 'schedule-entry';
      entry.dataset.index = scheduleIndex++;
      entry.innerHTML = `
        <select name="section[schedule][][day]" required>
          <option value="">Seleccione día</option>
          <option value="monday">Lunes</option>
          <option value="tuesday">Martes</option>
          <option value="wednesday">Miércoles</option>
          <option value="thursday">Jueves</option>
          <option value="friday">Viernes</option>
          <option value="saturday">Sábado</option>
          <option value="sunday">Domingo</option>
        </select>
        <input type="time" name="section[schedule][][start_time]" required placeholder="Hora inicio">
        <input type="time" name="section[schedule][][end_time]" required placeholder="Hora fin">
        <button type="button" class="btn btn-danger btn-sm" onclick="removeScheduleEntry(this)">Eliminar</button>
      `;
      container.appendChild(entry);
    }

    function removeScheduleEntry(button) {
      const entries = document.querySelectorAll('.schedule-entry');
      if (entries.length > 1) {
        button.parentElement.remove();
      } else {
        alert('Debe haber al menos un horario');
      }
    }
  </script>

  <style>
    .schedule-entry {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      align-items: center;
    }
    .schedule-entry select {
      flex: 1;
    }
    .schedule-entry input[type="time"] {
      flex: 1;
    }
  </style>

  <div class="form-group">
    <%= f.label :places, "Cupos Totales" %>
    <%= f.number_field :places, required: true, min: 1 %>
  </div>

  <div class="form-group">
    <%= f.label :start_date, "Fecha de Inicio" %>
    <%= f.date_field :start_date, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :end_date, "Fecha de Fin" %>
    <%= f.date_field :end_date, required: true %>
  </div>

  <div class="actions">
    <%= f.submit "Guardar", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_sections_path, class: "btn btn-secondary" %>
  </div>
<% end %>
