<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem;">
  <h1 style="color: #2c3e50;">Pagos a Docentes</h1>
  <div style="display: flex; align-items: center; gap: 0.5rem;">
    <%= link_to admin_teacher_payments_path(month: @nav_prev&.strftime('%Y-%m-%d'), status: @selected_status), class: "btn btn-secondary", style: "padding: 0.3rem 0.75rem;" do %>
      &larr;
    <% end %>
    <span style="font-weight: 600; color: #2c3e50; min-width: 120px; text-align: center;">
      <%= @selected_month ? I18n.l(@selected_month, format: '%B %Y').capitalize : 'Todos los meses' %>
    </span>
    <%= link_to admin_teacher_payments_path(month: @nav_next&.strftime('%Y-%m-%d'), status: @selected_status), class: "btn btn-secondary", style: "padding: 0.3rem 0.75rem;" do %>
      &rarr;
    <% end %>
  </div>
</div>

<% if @selected_month %>
  <div class="stats-grid" style="margin-bottom: 1.5rem;">
    <div class="stat-card">
      <h3>Docentes</h3>
      <div class="number"><%= @summary[:teachers] %></div>
    </div>
    <div class="stat-card">
      <h3>Total Matriculas</h3>
      <div class="number"><%= @summary[:enrollments] %></div>
    </div>
    <div class="stat-card">
      <h3>Total Mensualidades</h3>
      <div class="number" style="font-size: 1.5rem;"><%= number_to_currency(@summary[:tuition], precision: 0) %></div>
    </div>
    <div class="stat-card">
      <h3>Total a Pagar</h3>
      <div class="number" style="font-size: 1.5rem; color: #e74c3c;"><%= number_to_currency(@summary[:payment], precision: 0) %></div>
    </div>
  </div>
<% end %>

<div class="card">
  <% if @teacher_rows.any? %>
    <table>
      <thead>
        <tr>
          <th>Docente</th>
          <th style="text-align: center;">Matriculas</th>
          <th style="text-align: right;">Total Mensualidades</th>
          <th style="text-align: right;">A Pagar (42.5%)</th>
          <th style="text-align: center;">Estado</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @teacher_rows.each do |row| %>
          <tr>
            <td><strong><%= row[:name] %></strong></td>
            <td style="text-align: center;"><%= row[:enrollment_count] %></td>
            <td style="text-align: right;"><%= number_to_currency(row[:tuition_total], precision: 0) %></td>
            <td style="text-align: right; font-weight: 600; color: #2c3e50;"><%= number_to_currency(row[:payment_amount], precision: 0) %></td>
            <td style="text-align: center;">
              <%= form_tag toggle_status_admin_teacher_payment_path(row[:teacher]), method: :patch, style: "margin: 0;" do %>
                <%= hidden_field_tag :month, row[:month].strftime('%Y-%m-%d') %>
                <%= hidden_field_tag :filter_month, @selected_month&.strftime('%Y-%m-%d') %>
                <%= hidden_field_tag :filter_status, @selected_status %>
                <% paid = row[:status] == 'paid' %>
                <% if paid %>
                  <%= hidden_field_tag :new_status, 'pending' %>
                  <button type="submit" style="background: #d4edda; color: #155724; border: 1px solid #c3e6cb; padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.85rem; cursor: pointer; font-weight: 600;">
                    Pagado
                  </button>
                <% else %>
                  <%= hidden_field_tag :new_status, 'paid' %>
                  <button type="submit" style="background: #fff3cd; color: #856404; border: 1px solid #ffc107; padding: 0.3rem 0.75rem; border-radius: 20px; font-size: 0.85rem; cursor: pointer; font-weight: 600;">
                    Pendiente
                  </button>
                <% end %>
              <% end %>
            </td>
            <td>
              <%= link_to "Ver detalle", admin_teacher_payment_path(row[:teacher], month: row[:month].strftime('%Y-%m-%d')), class: "btn btn-primary", style: "padding: 0.3rem 0.75rem; font-size: 0.85rem;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <% if @selected_month && @teacher_rows.size > 1 %>
        <tfoot>
          <tr style="background: #f8f9fa; font-weight: 600;">
            <td>Total</td>
            <td style="text-align: center;"><%= @summary[:enrollments] %></td>
            <td style="text-align: right;"><%= number_to_currency(@summary[:tuition], precision: 0) %></td>
            <td style="text-align: right; color: #2c3e50;"><%= number_to_currency(@summary[:payment], precision: 0) %></td>
            <td></td>
            <td></td>
          </tr>
        </tfoot>
      <% end %>
    </table>
  <% else %>
    <p style="color: #7f8c8d; text-align: center; padding: 2rem;">No hay pagos registrados para este periodo.</p>
  <% end %>
</div>

<% if @selected_month.nil? %>
  <div style="margin-top: 1rem;">
    <div class="card" style="padding: 1rem;">
      <%= form_tag(admin_teacher_payments_path, method: :get, style: "display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;") do %>
        <span style="font-weight: 500; color: #2c3e50;">Filtrar:</span>
        <%= select_tag :month,
            options_for_select(
              @available_months.map { |m| [I18n.l(m, format: '%B %Y').capitalize, m.strftime('%Y-%m-%d')] },
              @selected_month&.strftime('%Y-%m-%d')
            ),
            include_blank: 'Todos los meses',
            style: "padding: 0.4rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 0.95rem;" %>
        <%= select_tag :status,
            options_for_select(
              [['Pagado', 'paid'], ['Pendiente', 'pending']],
              @selected_status
            ),
            include_blank: 'Todos los estados',
            style: "padding: 0.4rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; font-size: 0.95rem;" %>
        <%= submit_tag 'Filtrar', class: 'btn btn-primary', style: "padding: 0.4rem 1rem;" %>
        <% if @selected_month || @selected_status %>
          <%= link_to 'Limpiar', admin_teacher_payments_path, class: 'btn btn-secondary', style: "padding: 0.4rem 1rem;" %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
