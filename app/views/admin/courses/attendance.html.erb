<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
  <div>
    <h1 style="color: #2c3e50; margin-bottom: 0.25rem;">Pasar Asistencia</h1>
    <span style="color: #7f8c8d; font-size: 0.95rem;"><%= @course.title %></span>
  </div>
  <%= link_to 'Volver', admin_course_path(@course), class: 'btn btn-secondary' %>
</div>

<div class="card" style="margin-bottom: 1.5rem;">
  <%= form_tag attendance_admin_course_path(@course), method: :get,
        style: "display: flex; gap: 1rem; align-items: end; flex-wrap: wrap;" do %>
    <div>
      <label style="display: block; font-weight: 500; margin-bottom: 0.3rem; color: #2c3e50;">Sección</label>
      <%= select_tag :section_id,
            options_for_select(
              @sections.map { |s| ["#{s.weekday} #{s.formatted_schedule} - #{s.teacher.user.name}", s.id] },
              params[:section_id]
            ),
            include_blank: 'Seleccionar...',
            style: "padding: 0.4rem 0.75rem; border: 1px solid #ddd; border-radius: 4px; min-width: 320px;" %>
    </div>
    <%= submit_tag 'Cargar', class: 'btn btn-primary', style: "padding: 0.4rem 1rem;" %>
  <% end %>
</div>

<% if @selected_section %>
  <div class="section-content">
    <div class="mini-calendar-container">
      <div class="card">
        <div class="mini-calendar-header">
          <%= link_to attendance_admin_course_path(@course, section_id: @selected_section.id, date: @selected_date, month: @prev_month.month, year: @prev_month.year), class: "cal-nav" do %>
            &larr;
          <% end %>
          <span class="cal-month"><%= I18n.l(@calendar_date, format: '%B %Y').capitalize %></span>
          <%= link_to attendance_admin_course_path(@course, section_id: @selected_section.id, date: @selected_date, month: @next_month.month, year: @next_month.year), class: "cal-nav" do %>
            &rarr;
          <% end %>
        </div>

        <div class="mini-calendar">
          <div class="mini-cal-weekdays">
            <% %w[L M M J V S D].each do |day| %>
              <div class="mini-cal-weekday"><%= day %></div>
            <% end %>
          </div>
          <div class="mini-cal-body">
            <% @calendar_weeks.each do |week| %>
              <% week.each do |day| %>
                <% if day[:has_class] && day[:in_month] %>
                  <%
                    att = @attendance_by_date[day[:date]]
                    if att && att[:present] == att[:total] && att[:total] > 0
                      att_class = "attendance-done"
                    elsif att && att[:present] > 0
                      att_class = "attendance-partial"
                    else
                      att_class = ""
                    end
                  %>
                  <%= link_to day[:date].day,
                      attendance_admin_course_path(@course, section_id: @selected_section.id, date: day[:date], month: @month, year: @year),
                      class: "mini-cal-day has-class #{'selected' if day[:is_selected]} #{'today' if day[:is_today]} #{att_class}" %>
                <% elsif day[:is_section_day] && day[:in_month] %>
                  <%= link_to day[:date].day,
                      attendance_admin_course_path(@course, section_id: @selected_section.id, date: day[:date], month: @month, year: @year),
                      class: "mini-cal-day section-day #{'selected' if day[:is_selected]} #{'today' if day[:is_today]}" %>
                <% else %>
                  <div class="mini-cal-day <%= 'other-month' unless day[:in_month] %> <%= 'today' if day[:is_today] && day[:in_month] %>">
                    <%= day[:date].day %>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="calendar-legend">
          <span class="legend-item"><span class="legend-dot has-class"></span> Con alumnos</span>
          <span class="legend-item"><span class="legend-dot section-day-legend"></span> Sin alumnos</span>
          <span class="legend-item"><span class="legend-dot today"></span> Hoy</span>
          <% if can? :take_attendance, @selected_section %>
            <span class="legend-item"><span class="legend-dot attendance-complete"></span> Asistencia</span>
          <% end %>
        </div>
      </div>
    </div>

    <div class="students-list-container">
      <div class="card">
        <% if @selected_date %>
          <div class="selected-date-info" style="margin-bottom: 1rem;">
            <strong>
              <%= @selected_section.weekday %> <%= @selected_section.formatted_schedule %> —
              <%= I18n.l(@selected_date, format: '%d de %B, %Y') %>
            </strong>
            <span style="color: #7f8c8d; font-size: 0.9rem; margin-left: 0.5rem;">
              (<%= @enrollment_sections.size %> alumnos)
            </span>
          </div>

          <% if @enrollment_sections.any? && can?(:take_attendance, @selected_section) %>
            <%= form_tag take_attendance_admin_section_path(@selected_section), method: :patch do %>
              <%= hidden_field_tag :date, @selected_date %>
              <%= hidden_field_tag :course_id, @course.id %>

              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                <div style="display: flex; gap: 0.5rem;">
                  <button type="button" class="btn btn-secondary" style="padding: 0.3rem 0.75rem; font-size: 0.85rem;" onclick="toggleAll(true)">Todos presentes</button>
                  <button type="button" class="btn btn-secondary" style="padding: 0.3rem 0.75rem; font-size: 0.85rem;" onclick="toggleAll(false)">Desmarcar todos</button>
                </div>
                <span style="color: #7f8c8d; font-size: 0.9rem;">
                  <% present_count = @enrollment_sections.count { |es| es.attended? } %>
                  <strong id="present-count"><%= present_count %></strong>/<%= @enrollment_sections.size %> presentes
                </span>
              </div>

              <table>
                <thead>
                  <tr>
                    <th style="width: 40px;">#</th>
                    <th>Estudiante</th>
                    <% unless current_teacher? %>
                      <th>Email</th>
                    <% end %>
                    <th style="text-align: center; width: 100px;">Asistencia</th>
                  </tr>
                </thead>
                <tbody>
                  <% @enrollment_sections.each_with_index do |es, index| %>
                    <tr class="attendance-row <%= 'attended' if es.attended? %>">
                      <td><%= index + 1 %></td>
                      <td><strong><%= es.enrollment.student.user.name %></strong></td>
                      <% unless current_teacher? %>
                        <td><%= es.enrollment.student.user.email %></td>
                      <% end %>
                      <td style="text-align: center;">
                        <%= hidden_field_tag "attendance[#{es.id}][attended]", "0" %>
                        <label class="toggle-switch">
                          <%= check_box_tag "attendance[#{es.id}][attended]", "1", es.attended?, class: "attendance-checkbox", onchange: "updateCounter(this)" %>
                          <span class="toggle-slider"></span>
                        </label>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>

              <div style="margin-top: 1rem;">
                <%= submit_tag "Guardar Asistencia", class: "btn btn-success", style: "width: 100%; padding: 0.75rem; font-size: 1.05rem;" %>
              </div>
            <% end %>
          <% elsif @enrollment_sections.any? %>
            <table>
              <thead>
                <tr>
                  <th style="width: 40px;">#</th>
                  <th>Estudiante</th>
                  <th style="text-align: center;">Asistencia</th>
                </tr>
              </thead>
              <tbody>
                <% @enrollment_sections.each_with_index do |es, index| %>
                  <tr>
                    <td><%= index + 1 %></td>
                    <td><%= es.enrollment.student.user.name %></td>
                    <td style="text-align: center;"><%= es.attended? ? 'Presente' : (es.attended == false ? 'Ausente' : '—') %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p style="color: #7f8c8d; text-align: center; padding: 2rem;">No hay alumnos inscritos en esta sección para esta fecha.</p>
          <% end %>
        <% else %>
          <p style="color: #7f8c8d; text-align: center; padding: 2rem;">Selecciona una fecha en el calendario.</p>
        <% end %>
      </div>
    </div>
  </div>

  <% if @selected_date %>
    <script>
      function toggleAll(checked) {
        document.querySelectorAll('.attendance-checkbox').forEach(function(cb) {
          cb.checked = checked;
          updateRowStyle(cb);
        });
        updateCounterDisplay();
      }
      function updateCounter(cb) {
        updateRowStyle(cb);
        updateCounterDisplay();
      }
      function updateRowStyle(cb) {
        var row = cb.closest('.attendance-row');
        if (!row) return;
        if (cb.checked) { row.classList.add('attended'); }
        else { row.classList.remove('attended'); }
      }
      function updateCounterDisplay() {
        var present = document.querySelectorAll('.attendance-checkbox:checked').length;
        var el = document.getElementById('present-count');
        if (el) { el.textContent = present; }
      }
    </script>
  <% end %>
<% end %>
