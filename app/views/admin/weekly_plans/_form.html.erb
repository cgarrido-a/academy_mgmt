<%= form_with model: [:admin, weekly_plan], local: true do |f| %>
  <% if weekly_plan.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(weekly_plan.errors.count, "error") %> impidieron guardar este plan:</h3>
      <ul>
        <% weekly_plan.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :course_id, "Curso" %>
    <%= f.select :course_id,
        options_from_collection_for_select(@courses, :id, :title, weekly_plan.course_id),
        { include_blank: "Sin curso asignado" } %>
    <small style="color: #666;">Curso al que pertenece este plan (ej: "Mensual óleo", "Mensual acuarela")</small>
  </div>

  <div class="form-group">
    <%= f.label :plan, "Plan" %>
    <%= f.text_field :plan, required: true, placeholder: "Ej: 1 clase/semana, 2 clases/semana" %>
    <small style="color: #666;">Nombre o identificador del plan semanal</small>
  </div>

  <div class="form-group">
    <%= f.label :weekly_classes, "Clases por Semana" %>
    <%= f.number_field :weekly_classes, min: 1, placeholder: "Ej: 1, 2, 3" %>
    <small style="color: #666;">Cantidad de clases que el alumno toma por semana</small>
  </div>

  <div class="form-group">
    <%= f.label :number_of_classes, "Número Total de Clases" %>
    <%= f.number_field :number_of_classes, required: true, min: 1, placeholder: "Ej: 4, 8, 12" %>
    <small style="color: #666;">Total de clases incluidas en este plan (obligatorio)</small>
  </div>

  <div class="form-group">
    <%= f.label :price, "Precio Mensual (Lunes-Viernes)" %>
    <%= f.number_field :price, min: 0, placeholder: "Ej: 50000" %>
    <small style="color: #666;">Precio mensual del plan para clases de lunes a viernes</small>
  </div>

  <div class="form-group">
    <%= f.label :saturday_price, "Precio Mensual (Sábado)" %>
    <%= f.number_field :saturday_price, min: 0, placeholder: "Ej: 60000" %>
    <small style="color: #666;">Precio mensual del plan para clases de sábado</small>
  </div>

  <div class="form-group">
    <%= f.label :enrollment_fee, "Monto Matrícula" %>
    <%= f.number_field :enrollment_fee, min: 0, placeholder: "Ej: 5000" %>
    <small style="color: #666;">Monto fijo de matrícula/inscripción para este plan</small>
  </div>

  <div class="form-group">
    <%= f.label :event_type, "Tipo de Evento" %>
    <%= f.select :event_type, WeeklyPlan.event_types.map { |key, _| [key.titleize, key] }, { include_blank: "Ninguno" } %>
    <small style="color: #666;">Tipo especial de evento (opcional)</small>
  </div>

  <div class="form-group">
    <%= f.label :description, "Descripción" %>
    <%= f.text_area :description, required: true, rows: 3, placeholder: "Ej: Plan ideal para estudiantes que asisten 2 veces por semana" %>
  </div>

  <div class="actions">
    <%= f.submit "Guardar", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_weekly_plans_path, class: "btn btn-secondary" %>
  </div>
<% end %>
