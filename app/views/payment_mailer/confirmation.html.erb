<div style="font-family: Arial, Helvetica, sans-serif; color: #2c3e50; max-width: 600px; margin: 0 auto;">
  <h2 style="color: #27ae60; margin-bottom: 0.25rem;">✓ ¡Pago confirmado!</h2>
  <p style="margin-top: 0;">Hola <%= @user.name %>, recibimos tu pago correctamente. Aquí están los datos de tu matrícula.</p>

  <div style="background: #f4f6f7; border-radius: 8px; padding: 16px; margin: 16px 0;">
    <h3 style="margin: 0 0 8px 0;">Pago</h3>
    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
      <tr>
        <td style="padding: 4px 0; color: #7f8c8d;">Monto pagado</td>
        <td style="padding: 4px 0; text-align: right; font-weight: bold;">$<%= number_with_delimiter(@payment.amount.to_i) %></td>
      </tr>
      <tr>
        <td style="padding: 4px 0; color: #7f8c8d;">Fecha</td>
        <td style="padding: 4px 0; text-align: right;"><%= l(@payment.payment_date, format: '%d/%m/%Y') rescue @payment.payment_date %></td>
      </tr>
      <% if @payment.reference_number.present? %>
        <tr>
          <td style="padding: 4px 0; color: #7f8c8d;">Código de autorización</td>
          <td style="padding: 4px 0; text-align: right;"><%= @payment.reference_number %></td>
        </tr>
      <% end %>
    </table>
  </div>

  <div style="background: #f4f6f7; border-radius: 8px; padding: 16px; margin: 16px 0;">
    <h3 style="margin: 0 0 8px 0;">Matrícula #<%= @enrollment.id %></h3>
    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
      <tr>
        <td style="padding: 4px 0; color: #7f8c8d;">Curso(s)</td>
        <td style="padding: 4px 0; text-align: right;"><%= @courses.map(&:title).join(', ') %></td>
      </tr>
      <tr>
        <td style="padding: 4px 0; color: #7f8c8d;">Plan</td>
        <td style="padding: 4px 0; text-align: right;"><%= @enrollment.weekly_plan.plan %></td>
      </tr>
      <tr>
        <td style="padding: 4px 0; color: #7f8c8d;">Total clases</td>
        <td style="padding: 4px 0; text-align: right;"><%= @class_dates.size %></td>
      </tr>
    </table>

    <% @sections.each do |section| %>
      <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e0e0e0;">
        <strong><%= section.course.title %></strong> — <%= section.weekday %>, <%= section.formatted_schedule %>
      </div>
    <% end %>

    <% if @class_dates.any? %>
      <p style="margin: 12px 0 4px 0; color: #7f8c8d; font-size: 13px;">Fechas de tus clases:</p>
      <p style="margin: 0; font-size: 13px;">
        <%= @class_dates.map { |d| l(d, format: '%d/%m/%Y') rescue d.strftime('%d/%m/%Y') }.join(' · ') %>
      </p>
    <% end %>
  </div>

  <p style="color: #7f8c8d; font-size: 13px; margin-top: 24px;">
    Este es un correo automático de confirmación. Si tienes dudas sobre tu matrícula, responde a este mensaje.
  </p>
</div>
