<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Secciones</h2>
    <% if can? :create, Section %>
      <%= link_to "Nueva Sección", new_admin_section_path, class: "btn btn-success" %>
    <% end %>
  </div>

  <% if @sections.any? %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Curso</th>
          <th>Profesor</th>
          <th>Horario</th>
          <th>Día de la semana</th>
          <th>Cupos</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @sections.each do |section| %>
          <tr>
            <td><%= section.id %></td>
            <td><%= section.course.title %></td>
            <td><%= section.teacher.user.name %></td>
            <td><%= section.formatted_schedule %></td>
            <td><%= section.weekday %></td>
            <td><%= section.available_places %>/<%= section.places %></td>
            <td>
              <div class="actions">
                <%= link_to "Ver", admin_section_path(section), class: "btn btn-primary" %>
                <% if can? :update, section %>
                  <%= link_to "Editar", edit_admin_section_path(section), class: "btn btn-secondary" %>
                <% end %>
                <% if can? :destroy, section %>
                  <%= button_to "Eliminar", admin_section_path(section), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "btn btn-danger" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No hay secciones asignadas.</p>
  <% end %>
</div>
