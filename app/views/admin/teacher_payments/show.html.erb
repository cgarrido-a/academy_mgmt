<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
  <div>
    <h1 style="color: #2c3e50; margin-bottom: 0.25rem;"><%= @teacher.user.name %></h1>
    <span style="color: #7f8c8d; font-size: 0.95rem;"><%= I18n.l(@month, format: '%B %Y').capitalize %></span>
  </div>
  <%= link_to 'Volver', admin_teacher_payments_path(month: @month.strftime('%Y-%m-%d')), class: 'btn btn-primary' %>
</div>

<div class="stats-grid" style="margin-bottom: 1.5rem;">
  <div class="stat-card">
    <h3>Matriculas</h3>
    <div class="number"><%= @enrollment_rows.size %></div>
  </div>
  <div class="stat-card">
    <h3>Clases Asistidas</h3>
    <div class="number"><%= @attended_count %></div>
  </div>
  <div class="stat-card">
    <h3>Valor Clases Asistidas</h3>
    <div class="number" style="font-size: 1.5rem;"><%= number_to_currency(@total_tuition, precision: 0) %></div>
  </div>
  <div class="stat-card">
    <h3>A Pagar (42.5%)</h3>
    <div class="number" style="font-size: 1.5rem; color: #e74c3c;"><%= number_to_currency(@payment_amount, precision: 0) %></div>
  </div>
</div>

<% if @courses.count > 1 %>
  <div class="card" style="padding: 1rem; margin-bottom: 1.5rem;">
    <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
      <span style="font-weight: 500; color: #2c3e50;">Filtrar por curso:</span>
      <%= link_to "Todos", admin_teacher_payment_path(@teacher, month: params[:month]), class: "filter-btn #{@selected_course.nil? ? 'active' : ''}" %>
      <% @courses.each do |course| %>
        <%= link_to course.title, admin_teacher_payment_path(@teacher, month: params[:month], course_id: course.id), class: "filter-btn #{@selected_course == course.id ? 'active' : ''}" %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="card">
  <% if @enrollment_rows.any? %>
    <table>
      <thead>
        <tr>
          <th>Estudiante</th>
          <th>Curso</th>
          <th>Plan</th>
          <th style="text-align: center;">Asistencias</th>
          <th style="text-align: right;">Precio/Clase</th>
          <th style="text-align: right;">Valor Asistidas</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @enrollment_rows.each do |row| %>
          <tr>
            <td><strong><%= row[:enrollment].student.user.name %></strong></td>
            <td>
              <% row[:courses].each do |course| %>
                <span style="background: #e8f4fd; color: #2980b9; padding: 0.2rem 0.5rem; border-radius: 4px; font-size: 0.8rem; font-weight: 500;"><%= course.title %></span>
              <% end %>
            </td>
            <td>
              <%= row[:plan].plan %>
              <div style="font-size: 0.75rem; color: #7f8c8d;"><%= row[:plan].number_of_classes %> clases/mes</div>
            </td>
            <td style="text-align: center; font-weight: 600;"><%= row[:attended_count] %></td>
            <td style="text-align: right;">
              <% if row[:has_mixed_prices] %>
                <span title="Mezcla de tarifas regular y sábado">varía</span>
              <% else %>
                <%= number_to_currency(row[:price_per_class].round, precision: 0) %>
                <div style="font-size: 0.72rem; color: #27ae60; font-weight: 500; margin-top: 0.1rem;">
                  Para el docente: <%= number_to_currency((row[:price_per_class] * Admin::TeacherPaymentsController::PAYMENT_PERCENTAGE).round, precision: 0) %>
                </div>
              <% end %>
            </td>
            <td style="text-align: right; font-weight: 600;">
              <%= number_to_currency(row[:attended_value].round, precision: 0) %>
              <div style="font-size: 0.72rem; color: #27ae60; font-weight: 500; margin-top: 0.1rem;">
                Para el docente: <%= number_to_currency((row[:attended_value] * Admin::TeacherPaymentsController::PAYMENT_PERCENTAGE).round, precision: 0) %>
              </div>
            </td>
            <td>
              <%= link_to 'Ver', admin_enrollment_path(row[:enrollment]), class: 'btn btn-primary', style: "padding: 0.3rem 0.75rem; font-size: 0.85rem;" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: #7f8c8d; text-align: center; padding: 2rem;">No hay clases asistidas para este docente en el mes seleccionado.</p>
  <% end %>
</div>
