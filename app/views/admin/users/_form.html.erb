<%= form_with model: [:admin, user], local: true do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(user.errors.count, "error") %> impidieron guardar este usuario:</h3>
      <ul>
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="alert alert-error">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Nombre" %>
    <%= f.text_field :name, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :email, "Email" %>
    <%= f.email_field :email, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :password, "Contraseña" %>
    <%= f.password_field :password, required: user.new_record?, placeholder: user.new_record? ? "" : "Dejar en blanco para mantener la actual" %>
    <% if user.persisted? %>
      <small style="color: #7f8c8d;">Dejar en blanco si no deseas cambiar la contraseña</small>
    <% end %>
  </div>

  <div class="form-group">
    <%= label_tag :roles, "Roles" %>
    <small style="display: block; color: #7f8c8d; margin-bottom: 0.5rem;">
      Un usuario puede tener más de un rol (por ejemplo, docente y administrador).
      Los roles ya asignados no se pueden quitar desde aquí.
    </small>
    <div style="display: flex; flex-direction: column; gap: 0.4rem;">
      <% %w[teacher student admin].each do |role_key| %>
        <% already = assigned_role_keys(user).include?(role_key) %>
        <label style="display: flex; align-items: center; gap: 0.5rem; font-weight: normal;">
          <%= check_box_tag 'user[roles][]', role_key, already,
                id: "role_#{role_key}", disabled: already, onchange: 'toggleRoleFields()' %>
          <%= role_badge(role_key) %>
          <% if already %><small style="color: #7f8c8d;">(ya asignado)</small><% end %>
        </label>
      <% end %>
    </div>
  </div>

  <div id="teacher_fields" style="display: none;">
    <div class="form-group">
      <%= label_tag 'user[profession]', "Profesión (para docentes)" %>
      <%= text_field_tag 'user[profession]', user.teacher&.profession, placeholder: "Ej: Ingeniera, Licenciada, etc." %>
    </div>
  </div>

  <div id="admin_fields" style="display: none;">
    <div class="form-group">
      <%= label_tag 'user[admin_type]', "Tipo de Admin" %>
      <%= select_tag 'user[admin_type]', options_for_select([
        ['Seleccionar tipo', ''],
        ['Super Admin', 'super'],
        ['Admin Regular', 'regular']
      ], user.admin_user&.admin_type) %>
    </div>
  </div>

  <script>
    function toggleRoleFields() {
      var teacher = document.getElementById('role_teacher');
      var admin = document.getElementById('role_admin');
      document.getElementById('teacher_fields').style.display = (teacher && teacher.checked) ? 'block' : 'none';
      document.getElementById('admin_fields').style.display = (admin && admin.checked) ? 'block' : 'none';
    }
    document.addEventListener('DOMContentLoaded', toggleRoleFields);
  </script>

  <div class="actions">
    <%= f.submit user.new_record? ? "Crear Usuario" : "Actualizar Usuario", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_users_path, class: "btn btn-secondary" %>
  </div>
<% end %>
