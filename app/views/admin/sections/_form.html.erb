<%= form_with model: [:admin, section], local: true do |f| %>
  <% if section.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(section.errors.count, "error") %> impidieron guardar esta sección:</h3>
      <ul>
        <% section.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :course_id, "Curso" %>
    <%= f.select :course_id, options_from_collection_for_select(courses, :id, :title, section.course_id), { prompt: "Seleccione un curso" }, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :teacher_id, "Profesor" %>
    <%= f.select :teacher_id, options_from_collection_for_select(teachers, :id, ->(t) { t.user.name }, section.teacher_id), { prompt: "Seleccione un profesor" }, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :weekday, "Día de la semana" %>
    <%= f.select :weekday, [
      ['Lunes', 'Lunes'],
      ['Martes', 'Martes'],
      ['Miércoles', 'Miércoles'],
      ['Jueves', 'Jueves'],
      ['Viernes', 'Viernes'],
      ['Sábado', 'Sábado'],
      ['Domingo', 'Domingo']
    ], { prompt: "Seleccione un día" }, required: true %>
  </div>

  <div class="form-group">
    <label>Horario</label>
    <div class="schedule-entry">
      <% schedule_entry = section.schedule&.first || {} %>
      <input type="time" name="section[schedule][][start_time]" value="<%= schedule_entry['start_time'] %>" required placeholder="Hora inicio">
      <span>a</span>
      <input type="time" name="section[schedule][][end_time]" value="<%= schedule_entry['end_time'] %>" required placeholder="Hora fin">
    </div>
  </div>

  <style>
    .schedule-entry {
      display: flex;
      gap: 10px;
      align-items: center;
    }
    .schedule-entry input[type="time"] {
      flex: 1;
    }
    .schedule-entry span {
      color: #666;
    }
  </style>

  <div class="form-group">
    <%= f.label :places, "Cupos Totales" %>
    <%= f.number_field :places, required: true, min: 1 %>
  </div>

  <div class="actions">
    <%= f.submit "Guardar", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_sections_path, class: "btn btn-secondary" %>
  </div>
<% end %>
