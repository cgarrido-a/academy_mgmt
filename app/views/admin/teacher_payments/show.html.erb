<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Matrículas de <%= @teacher.user.name %></h1>
  <%= link_to 'Volver', admin_teacher_payments_path, class: 'btn btn-secondary' %>
</div>

<div class="card mb-4">
  <div class="card-body">
    <h5 class="card-title">Filtrar por Curso</h5>
    <%= form_tag(admin_teacher_payment_path(@teacher), method: :get, class: 'd-flex gap-2 align-items-end') do %>
      <%= hidden_field_tag :month, params[:month] %>
      <div class="flex-grow-1">
        <%= select_tag :course_id,
            options_from_collection_for_select(@courses, :id, :title, @selected_course),
            include_blank: 'Todos los cursos',
            class: 'form-select' %>
      </div>
      <%= submit_tag 'Filtrar', class: 'btn btn-primary' %>
      <% if params[:course_id].present? %>
        <%= link_to 'Limpiar', admin_teacher_payment_path(@teacher, month: params[:month]), class: 'btn btn-outline-secondary' %>
      <% end %>
    <% end %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <h5 class="card-title">Resumen - <%= l(@month, format: '%B %Y') %></h5>
    <div class="row">
      <div class="col-md-4">
        <strong>Total Matrículas:</strong> <%= @enrollments.count %>
      </div>
      <div class="col-md-4">
        <strong>Total Mensualidades:</strong> <%= number_to_currency(@total_tuition) %>
      </div>
      <div class="col-md-4">
        <strong>Monto a Pagar (42.5%):</strong> <%= number_to_currency(@payment_amount) %>
      </div>
    </div>
  </div>
</div>

<table class="table table-striped">
  <thead>
    <tr>
      <th>Estudiante</th>
      <th>Curso</th>
      <th>Plan</th>
      <th>Mensualidad</th>
      <th>Fecha Matrícula</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% @enrollments.each do |enrollment| %>
      <tr>
        <td><%= enrollment.student.user.name %></td>
        <td>
          <% enrollment.enrollment_sections.map { |es| es.section.course }.uniq.each do |course| %>
            <span class="badge bg-info"><%= course.title %></span>
          <% end %>
        </td>
        <td><%= enrollment.weekly_plan.plan %></td>
        <td><%= number_to_currency(enrollment.total_tuition_fee) %></td>
        <td><%= l(enrollment.created_at.to_date, format: :short) %></td>
        <td>
          <%= link_to 'Ver', admin_enrollment_path(enrollment), class: 'btn btn-sm btn-outline-primary' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @enrollments.empty? %>
  <div class="alert alert-info">
    No hay matrículas registradas para este profesor en el mes seleccionado.
  </div>
<% end %>
