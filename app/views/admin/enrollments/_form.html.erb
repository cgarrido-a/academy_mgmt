<%= form_with model: [:admin, enrollment], local: true do |f| %>
  <% if enrollment.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(enrollment.errors.count, "error") %> impidieron guardar esta inscripción:</h3>
      <ul>
        <% enrollment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :student_id, "Estudiante" %>
    <%= f.select :student_id,
        options_from_collection_for_select(students, :id, ->(s) { "#{s.user.name} (#{s.user.email})" }, enrollment.student_id),
        { prompt: "Seleccione un estudiante" },
        required: true %>
  </div>

  <div class="form-group">
    <%= f.label :section_ids, "Secciones" %>
    <%= f.select :section_ids,
        grouped_options_for_select(
          sections.group_by(&:course).map { |course, course_sections|
            [course.title, course_sections.map { |s| ["#{s.weekday} #{s.formatted_schedule} - #{s.teacher.user.name} (#{s.places} cupos)", s.id] }]
          },
          enrollment.section_ids
        ),
        { prompt: "Seleccione una o más secciones" },
        { multiple: true, required: true, size: 10 } %>
    <small style="color: #666;">Mantén presionado Ctrl (Cmd en Mac) para seleccionar múltiples secciones</small>
  </div>

  <div class="form-group">
    <%= f.label :section_date, "Fecha de las clases" %>

    <div id="available-dates-container">
      <p style="color: #666; font-style: italic;">Selecciona una sección primero para ver las fechas disponibles</p>
    </div>

    <%= f.hidden_field :section_date, id: 'selected_date_field', value: enrollment.new_record? ? '' : enrollment.enrollment_sections.first&.date %>

    <small style="color: #666;">Selecciona una fecha de las disponibles (se aplicará a todas las secciones seleccionadas)</small>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sectionSelect = document.querySelector('select[name="enrollment[section_ids][]"]');
      const datesContainer = document.getElementById('available-dates-container');
      const dateField = document.getElementById('selected_date_field');

      if (sectionSelect) {
        sectionSelect.addEventListener('change', async function() {
          const selectedSections = Array.from(sectionSelect.selectedOptions).map(opt => opt.value).filter(v => v);

          if (selectedSections.length === 0) {
            datesContainer.innerHTML = '<p style="color: #666; font-style: italic;">Selecciona una sección primero para ver las fechas disponibles</p>';
            return;
          }

          // Usar la primera sección seleccionada para mostrar fechas
          const sectionId = selectedSections[0];

          try {
            datesContainer.innerHTML = '<p style="color: #999;">Cargando fechas disponibles...</p>';

            // Llamar al API para obtener fechas disponibles
            const response = await fetch(`/api/v1/sections/${sectionId}/calendar`);
            const data = await response.json();

            if (data.success && data.data.dates.length > 0) {
              // Mostrar fechas como radio buttons
              let html = `
                <div style="max-height: 300px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; border-radius: 4px;">
                  <p style="margin-top: 0; font-weight: bold; color: #333;">
                    ${data.data.course} - ${data.data.weekday} ${data.data.schedule[0]}
                  </p>
              `;

              data.data.dates.forEach((dateInfo, index) => {
                const dateObj = new Date(dateInfo.date + 'T00:00:00');
                const formattedDate = dateObj.toLocaleDateString('es-ES', {
                  weekday: 'long',
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                });

                const isAvailable = dateInfo.available_places > 0;
                const currentValue = dateField.value;
                const isChecked = currentValue === dateInfo.date;

                html += `
                  <div style="margin-bottom: 8px; padding: 8px; background: ${isAvailable ? '#f9f9f9' : '#ffe6e6'}; border-radius: 4px; ${!isAvailable ? 'opacity: 0.6;' : ''}">
                    <label style="display: flex; align-items: center; cursor: ${isAvailable ? 'pointer' : 'not-allowed'};">
                      <input
                        type="radio"
                        name="date_selection"
                        value="${dateInfo.date}"
                        ${!isAvailable ? 'disabled' : ''}
                        ${isChecked ? 'checked' : ''}
                        style="margin-right: 10px;"
                        onchange="document.getElementById('selected_date_field').value = this.value"
                      />
                      <span style="flex: 1;">
                        <strong>${formattedDate}</strong>
                      </span>
                      <span style="color: ${isAvailable ? '#27ae60' : '#e74c3c'}; font-weight: bold;">
                        ${dateInfo.available_places}/${dateInfo.total_places} cupos
                      </span>
                    </label>
                  </div>
                `;
              });

              html += '</div>';

              if (selectedSections.length > 1) {
                html += `
                  <p style="margin-top: 10px; color: #f39c12; font-size: 0.9em;">
                    ⚠️ Nota: Seleccionaste múltiples secciones. La fecha elegida se aplicará a todas.
                  </p>
                `;
              }

              datesContainer.innerHTML = html;
            } else {
              datesContainer.innerHTML = '<p style="color: #e74c3c;">No hay fechas disponibles para esta sección.</p>';
            }
          } catch (error) {
            console.error('Error al cargar fechas:', error);
            datesContainer.innerHTML = '<p style="color: #e74c3c;">Error al cargar las fechas disponibles. Intenta de nuevo.</p>';
          }
        });
      }
    });
  </script>

  <div class="form-group">
    <%= f.label :weekly_plan_id, "Plan de Pago" %>
    <%= f.select :weekly_plan_id,
        options_from_collection_for_select(weekly_plans, :id, :description, enrollment.weekly_plan_id),
        { prompt: "Seleccione un plan de pago" },
        required: true %>
  </div>

  <div class="form-group">
    <%= f.label :payment_method_id, "Método de Pago" %>
    <%= f.select :payment_method_id,
        options_from_collection_for_select(payment_methods, :id, :payment_method, enrollment.payment_method_id),
        { prompt: "Seleccione un método de pago" },
        required: true %>
  </div>

  <div class="form-group">
    <%= f.label :enrollment_amount, "Monto Matrícula" %>
    <%= f.number_field :enrollment_amount, required: true, min: 0, step: 0.01, placeholder: "Ej: 500", id: 'enrollment_amount_field' %>
    <small style="color: #666;">Pago inicial de inscripción/matrícula</small>
  </div>

  <div class="form-group">
    <%= f.label :payment_date, "Fecha de Pago Matrícula" %>
    <%= f.date_field :payment_date %>
    <small style="color: #666;">Opcional - Fecha del pago de matrícula</small>
  </div>

  <div class="actions">
    <%= f.submit "Guardar", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_enrollments_path, class: "btn btn-secondary" %>
  </div>
<% end %>
