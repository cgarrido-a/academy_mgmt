<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Planes Semanales <span style="color: #7f8c8d; font-weight: 400; font-size: 0.95rem;">(<%= @weekly_plans.size %>)</span></h2>
    <%= link_to "Nuevo Plan", new_admin_weekly_plan_path, class: "btn btn-success" %>
  </div>

  <%= form_with url: admin_weekly_plans_path, method: :get, local: true, style: "margin-bottom: 1.25rem;" do %>
    <div style="display: flex; gap: 0.5rem; max-width: 500px; align-items: center;">
      <%= select_tag :course_id,
            options_for_select(
              [["Todos los cursos", ""], ["Sin curso asignado", "none"]] +
              @courses.map { |c| [c.title, c.id.to_s] },
              @course_id),
            onchange: "this.form.requestSubmit()",
            style: "flex: 1; padding: 0.55rem 0.85rem; border: 1px solid #dee2e6; border-radius: 6px; font-size: 0.95rem;" %>
      <%= submit_tag "Filtrar", class: "btn btn-primary" %>
      <% if @course_id %>
        <%= link_to "Limpiar", admin_weekly_plans_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>

  <% if @weekly_plans.any? %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Curso</th>
          <th>Plan</th>
          <th>Clases/Semana</th>
          <th>Total Clases</th>
          <th>Precio Mensual</th>
          <th>Precio Sábado</th>
          <th>Matrícula</th>
          <th>Tipo Evento</th>
          <th>Inscripciones</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @weekly_plans.each do |plan| %>
          <tr>
            <td><%= plan.id %></td>
            <td><%= plan.course&.title || '<span style="color: #e67e22;">Sin curso</span>'.html_safe %></td>
            <td><%= plan.plan %></td>
            <td><%= plan.weekly_classes || '-' %></td>
            <td><%= plan.number_of_classes || '<span style="color: #e74c3c;">Sin configurar</span>'.html_safe %></td>
            <td>$<%= number_with_delimiter(plan.price || 0) %></td>
            <td>$<%= number_with_delimiter(plan.saturday_price || 0) %></td>
            <td>$<%= number_with_delimiter(plan.enrollment_fee || 0) %></td>
            <td><%= plan.event_type&.titleize || '-' %></td>
            <td><%= plan.enrollments.count %></td>
            <td>
              <div class="actions">
                <%= link_to "Ver", admin_weekly_plan_path(plan), class: "btn btn-primary" %>
                <%= link_to "Editar", edit_admin_weekly_plan_path(plan), class: "btn btn-secondary" %>
                <%= button_to "Eliminar", admin_weekly_plan_path(plan), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "btn btn-danger" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No hay planes de pago registrados. <%= link_to "Crear el primero", new_admin_weekly_plan_path %></p>
  <% end %>
</div>
