<%= form_with model: [:admin, user], local: true do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(user.errors.count, "error") %> impidieron guardar este usuario:</h3>
      <ul>
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="alert alert-error">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, "Nombre" %>
    <%= f.text_field :name, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :email, "Email" %>
    <%= f.email_field :email, required: true %>
  </div>

  <div class="form-group">
    <%= f.label :password, "Contraseña" %>
    <%= f.password_field :password, required: user.new_record?, placeholder: user.new_record? ? "" : "Dejar en blanco para mantener la actual" %>
    <% if user.persisted? %>
      <small style="color: #7f8c8d;">Dejar en blanco si no deseas cambiar la contraseña</small>
    <% end %>
  </div>

  <% if user.new_record? %>
    <div class="form-group">
      <%= label_tag :role, "Rol" %>
      <%= select_tag 'user[role]', options_for_select([
        ['Seleccionar rol', ''],
        ['Estudiante', 'student'],
        ['Profesor', 'teacher'],
        ['Administrador', 'admin']
      ]), required: true, id: 'user_role', onchange: 'toggleRoleFields()' %>
    </div>

    <div id="teacher_fields" style="display: none;">
      <div class="form-group">
        <%= label_tag 'user[profession]', "Profesión (para profesores)" %>
        <%= text_field_tag 'user[profession]', '', placeholder: "Ej: Ingeniero, Licenciado, etc." %>
      </div>
    </div>

    <div id="admin_fields" style="display: none;">
      <div class="form-group">
        <%= label_tag 'user[admin_type]', "Tipo de Admin" %>
        <%= select_tag 'user[admin_type]', options_for_select([
          ['Seleccionar tipo', ''],
          ['Super Admin', 'super'],
          ['Admin Regular', 'regular']
        ]) %>
      </div>
    </div>

    <script>
      function toggleRoleFields() {
        const role = document.getElementById('user_role').value;
        const teacherFields = document.getElementById('teacher_fields');
        const adminFields = document.getElementById('admin_fields');

        // Ocultar todos los campos
        teacherFields.style.display = 'none';
        adminFields.style.display = 'none';

        // Mostrar campos según rol
        if (role === 'teacher') {
          teacherFields.style.display = 'block';
        } else if (role === 'admin') {
          adminFields.style.display = 'block';
        }
      }

      // Ejecutar al cargar la página
      document.addEventListener('DOMContentLoaded', toggleRoleFields);
    </script>
  <% end %>

  <div class="actions">
    <%= f.submit user.new_record? ? "Crear Usuario" : "Actualizar Usuario", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_users_path, class: "btn btn-secondary" %>
  </div>
<% end %>
