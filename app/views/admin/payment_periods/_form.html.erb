<%= form_with model: [:admin, payment_period], local: true do |f| %>
  <% if payment_period.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(payment_period.errors.count, "error") %> impidieron guardar este período:</h3>
      <ul>
        <% payment_period.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :months, "Cantidad de Meses" %>
    <%= f.number_field :months, required: true, min: 1, placeholder: "Ej: 1, 2, 3, 6" %>
    <small style="color: #666;">Número de meses del período de pago</small>
  </div>

  <div class="form-group">
    <%= f.label :discount_percentage, "Descuento (%)" %>
    <%= f.number_field :discount_percentage, required: true, min: 0, max: 100, step: 0.01, placeholder: "Ej: 10, 15, 40" %>
    <small style="color: #666;">Porcentaje de descuento (0-100)</small>
  </div>

  <div class="form-group">
    <%= f.label :description, "Descripción (opcional)" %>
    <%= f.text_area :description, rows: 3, placeholder: "Ej: Pago adelantado con 10% de descuento" %>
  </div>

  <div class="actions">
    <%= f.submit "Guardar", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_payment_periods_path, class: "btn btn-secondary" %>
  </div>
<% end %>
