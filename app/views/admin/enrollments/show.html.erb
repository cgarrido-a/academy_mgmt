<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Inscripción #<%= @enrollment.id %></h2>
    <div class="actions">
      <%= link_to "Editar", edit_admin_enrollment_path(@enrollment), class: "btn btn-secondary" %>
      <%= link_to "Volver", admin_enrollments_path, class: "btn btn-primary" %>
    </div>
  </div>

  <h3>Información del Estudiante</h3>
  <div class="form-group">
    <strong>Nombre:</strong>
    <p><%= @enrollment.student.user.name %></p>
  </div>

  <div class="form-group">
    <strong>Email:</strong>
    <p><%= @enrollment.student.user.email %></p>
  </div>

  <h3>Información de Pago</h3>
  <div class="form-group">
    <strong>Plan de Pago:</strong>
    <p><%= @enrollment.weekly_plan.description %> (<%= @enrollment.weekly_plan.number_of_classes %> clases)</p>
  </div>

  <div class="form-group">
    <strong>Método de Pago:</strong>
    <p><%= @enrollment.payment_method.payment_method %></p>
  </div>

  <div class="form-group">
    <strong>Monto de Matrícula:</strong>
    <p>$<%= number_with_delimiter(@enrollment.enrollment_amount) %></p>
  </div>

  <div class="form-group">
    <strong>Monto Total (Arancel):</strong>
    <p>$<%= number_with_delimiter(@enrollment.total_tuition_fee) %></p>
  </div>

  <div class="form-group">
    <strong>Fecha de Inscripción:</strong>
    <p><%= @enrollment.created_at.strftime('%d/%m/%Y %H:%M') %></p>
  </div>
</div>

<div class="card">
  <h2>Clases Programadas (<%= @enrollment.enrollment_sections.count %>)</h2>

  <% if @enrollment.enrollment_sections.any? %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; margin-top: 1rem;">
      <% @enrollment.enrollment_sections.order(:date).each do |enrollment_section| %>
        <% section = enrollment_section.section %>
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 1rem; background: #f8f9fa; position: relative;">
          <div style="background: #007bff; color: white; padding: 0.5rem; margin: -1rem -1rem 1rem -1rem; border-radius: 8px 8px 0 0; font-weight: bold; display: flex; justify-content: space-between; align-items: center;">
            <span><%= enrollment_section.date.strftime('%d/%m/%Y') %></span>
            <%= link_to "Editar", edit_admin_enrollment_section_path(enrollment_section),
                style: "color: white; text-decoration: underline; font-size: 0.9rem; font-weight: normal;" %>
          </div>

          <div style="margin-bottom: 0.5rem;">
            <strong>Curso:</strong><br>
            <%= link_to section.course.title, admin_course_path(section.course), style: "color: #007bff;" %>
          </div>

          <div style="margin-bottom: 0.5rem;">
            <strong>Día:</strong> <%= section.weekday %>
          </div>

          <div style="margin-bottom: 0.5rem;">
            <strong>Horario:</strong> <%= section.formatted_schedule %>
          </div>

          <div style="margin-bottom: 0.5rem;">
            <strong>Profesor:</strong> <%= section.teacher.user.name %>
          </div>

          <div style="margin-top: 1rem; padding-top: 0.5rem; border-top: 1px solid #ddd; font-size: 0.9rem; color: #666;">
            Sección #<%= section.id %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p style="color: #666; font-style: italic;">No hay clases programadas para esta inscripción.</p>
  <% end %>
</div>

<div class="card">
  <h2>Historial de Pagos</h2>

  <% enrollment_fee_payment = @enrollment.enrollment_fee_payment %>
  <% if enrollment_fee_payment %>
    <div style="background: #e8f5e9; padding: 1rem; border-radius: 4px; margin-bottom: 1rem;">
      <strong>Pago de Matrícula</strong>
      <p>Monto: <strong>$<%= number_with_delimiter(enrollment_fee_payment.amount) %></strong></p>
      <p>Fecha: <%= enrollment_fee_payment.payment_date.strftime('%d/%m/%Y') %></p>
      <p>Método: <%= enrollment_fee_payment.payment_method.payment_method %></p>
      <%= link_to "Ver Detalle", admin_payment_path(enrollment_fee_payment), class: "btn btn-primary" %>
    </div>
  <% else %>
    <div style="background: #fff3cd; padding: 1rem; border-radius: 4px; margin-bottom: 1rem;">
      <p style="margin: 0;">⚠️ No se ha registrado el pago de matrícula</p>
      <%= link_to "Registrar Pago de Matrícula", new_admin_payment_path(enrollment_id: @enrollment.id, payment_type: 'enrollment_fee'), class: "btn btn-success", style: "margin-top: 0.5rem;" %>
    </div>
  <% end %>

  <div style="margin-top: 1.5rem; padding: 1rem; background: #f8f9fa; border-radius: 4px;">
    <strong>Total Pagado:</strong>
    <span style="font-size: 1.5rem; color: #27ae60; font-weight: bold;">
      $<%= number_with_delimiter(@enrollment.total_paid) %>
    </span>
  </div>
</div>
