<style>
  .profile-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  @media (max-width: 800px) { .profile-grid { grid-template-columns: 1fr; } }

  .profile-card h3 { font-size: 1rem; color: #2c3e50; margin: 0 0 1rem 0; padding-bottom: 0.5rem; border-bottom: 1px solid #e9ecef; }
  .profile-readonly { padding: 0.55rem 0.85rem; background: #f8f9fa; border: 1px solid #e9ecef; border-radius: 4px; color: #7f8c8d; }
  .role-pill { display: inline-block; padding: 0.25rem 0.7rem; border-radius: 12px; font-size: 0.78rem; font-weight: 600; }
  .role-admin   { background: #fee2e2; color: #991b1b; }
  .role-teacher { background: #dbeafe; color: #1e40af; }
  .role-student { background: #d1fae5; color: #065f46; }
  .helper { font-size: 0.78rem; color: #7f8c8d; margin-top: 0.25rem; }
</style>

<div class="card">
  <h2 style="margin-bottom: 0.25rem;">Mi perfil</h2>
  <p style="color: #7f8c8d; font-size: 0.9rem; margin-bottom: 1.5rem;">
    Actualiza tus datos personales y tu contraseña.
  </p>

  <div class="form-group">
    <label>Email</label>
    <div class="profile-readonly"><%= @user.email %></div>
    <div class="helper">El email no se puede cambiar desde aquí. Si necesitas modificarlo, contacta a un administrador.</div>
  </div>

  <div class="form-group">
    <label>Rol</label>
    <div>
      <% if @user.admin_user.present? %>
        <span class="role-pill role-admin">Administrador</span>
        <% if @user.admin_user.admin_type.present? %>
          <span style="color: #7f8c8d; margin-left: 0.5rem; font-size: 0.85rem;"><%= @user.admin_user.admin_type.humanize %></span>
        <% end %>
      <% elsif @user.teacher.present? %>
        <span class="role-pill role-teacher">Profesor</span>
        <% if @user.teacher.profession.present? %>
          <span style="color: #7f8c8d; margin-left: 0.5rem; font-size: 0.85rem;"><%= @user.teacher.profession %></span>
        <% end %>
      <% elsif @user.student.present? %>
        <span class="role-pill role-student">Estudiante</span>
      <% end %>
    </div>
  </div>
</div>

<div class="profile-grid">
  <%# === DATOS PERSONALES === %>
  <div class="card profile-card">
    <h3>Datos personales</h3>

    <%= form_with model: @user, url: personal_admin_profile_path, method: :patch, local: true do |f| %>
      <div class="form-group">
        <%= f.label :name, 'Nombre completo' %>
        <%= f.text_field :name, required: true %>
      </div>

      <div class="form-group">
        <%= f.label :phone, 'Teléfono' %>
        <%= f.telephone_field :phone, placeholder: '+56 9 1234 5678' %>
      </div>

      <%= f.submit 'Guardar cambios', class: 'btn btn-success' %>
    <% end %>
  </div>

  <%# === CONTRASEÑA === %>
  <div class="card profile-card">
    <h3>Cambiar contraseña</h3>

    <%= form_with model: @user, url: password_admin_profile_path, method: :patch, local: true do |f| %>
      <div class="form-group">
        <%= f.label :current_password, 'Contraseña actual' %>
        <%= f.password_field :current_password, required: true, autocomplete: 'current-password' %>
      </div>

      <div class="form-group">
        <%= f.label :password, 'Nueva contraseña' %>
        <%= f.password_field :password, required: true, autocomplete: 'new-password' %>
        <div class="helper">Mínimo 6 caracteres.</div>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, 'Confirmar nueva contraseña' %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: 'new-password' %>
      </div>

      <%= f.submit 'Actualizar contraseña', class: 'btn btn-success' %>
    <% end %>
  </div>
</div>
