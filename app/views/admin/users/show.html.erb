<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2><%= @user.name %></h2>
    <div class="actions">
      <%= link_to "Editar", edit_admin_user_path(@user), class: "btn btn-secondary" %>
      <%= link_to "Volver", admin_users_path, class: "btn btn-primary" %>
    </div>
  </div>

  <div class="form-group">
    <strong>Email:</strong>
    <p><%= @user.email %></p>
  </div>

  <div class="form-group">
    <strong>Roles:</strong>
    <p>
      <% roles = assigned_role_keys(@user) %>
      <% if roles.any? %>
        <% roles.each do |role_key| %><%= role_badge(role_key) %><% end %>
      <% else %>
        <span style="background: #95a5a6; color: white; padding: 0.25rem 0.5rem; border-radius: 4px;">Sin rol</span>
      <% end %>
    </p>
  </div>

  <% if @user.teacher %>
    <div class="form-group">
      <strong>Profesión:</strong>
      <p><%= @user.teacher.profession || 'No especificada' %></p>
    </div>
  <% end %>

  <% if @user.student && @user.phone.present? %>
    <div class="form-group">
      <strong>Teléfono:</strong>
      <p><%= @user.phone %></p>
    </div>
  <% end %>

  <% if @user.admin_user %>
    <div class="form-group">
      <strong>Tipo de Admin:</strong>
      <p><%= @user.admin_user.admin_type&.capitalize || 'No especificado' %></p>
    </div>
  <% end %>

  <div class="form-group">
    <strong>Fecha de Creación:</strong>
    <p><%= @user.created_at.strftime('%d/%m/%Y %H:%M') %></p>
  </div>
</div>

<% if @user.student %>
  <style>
    .stu-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 0.85rem; margin-bottom: 1.5rem; }
    .stu-stat { background: white; border: 1px solid #e9ecef; border-radius: 8px; padding: 0.95rem 1rem; }
    .stu-stat .label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.04em; color: #7f8c8d; margin-bottom: 0.4rem; }
    .stu-stat .value { font-size: 1.5rem; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1; color: #2c3e50; }
    .stu-stat .sub { font-size: 0.78rem; color: #7f8c8d; margin-top: 0.35rem; }
    .stu-stat.attendance .value { color: #3498db; }
    .stu-stat.makeups    .value { color: #5b21b6; }
    .stu-stat.balance.debt  .value { color: #e74c3c; }
    .stu-stat.balance.clear .value { color: #27ae60; }

    .enr-card { display: grid; grid-template-columns: 1fr auto; gap: 1rem; padding: 1rem; border: 1px solid #e9ecef; border-radius: 8px; margin-bottom: 0.85rem; background: white; align-items: center; }
    .enr-card-info h4 { margin: 0 0 0.35rem 0; font-size: 1rem; color: #2c3e50; font-weight: 600; }
    .enr-card-meta { color: #7f8c8d; font-size: 0.85rem; line-height: 1.5; }
    .enr-card-meta strong { color: #2c3e50; font-weight: 600; }
    .enr-card-actions { display: flex; gap: 0.5rem; align-items: center; }
    .balance-tag { display: inline-block; padding: 0.18rem 0.55rem; border-radius: 10px; font-size: 0.75rem; font-weight: 600; }
    .balance-tag.debt { background: #fee2e2; color: #991b1b; }
    .balance-tag.clear { background: #d1fae5; color: #065f46; }
  </style>

  <% if @student_enrollments.any? %>
    <div class="stu-stats">
      <div class="stu-stat attendance">
        <div class="label">Asistencia agregada</div>
        <div class="value"><%= @student_attendance_rate ? "#{@student_attendance_rate}%" : '—' %></div>
        <div class="sub">Sobre <%= @student_total_classes %> clases del plan</div>
      </div>
      <div class="stu-stat">
        <div class="label">Inscripciones</div>
        <div class="value"><%= @student_enrollments.size %></div>
        <div class="sub">Total histórico</div>
      </div>
      <div class="stu-stat makeups">
        <div class="label">Recuperatorios</div>
        <div class="value"><%= @student_makeup_total %></div>
      </div>
      <div class="stu-stat balance <%= @student_balance.positive? ? 'debt' : 'clear' %>">
        <div class="label">Saldo</div>
        <div class="value">
          <% if @student_balance.positive? %>
            $<%= number_with_delimiter(@student_balance) %>
          <% else %>
            ✓ Al día
          <% end %>
        </div>
        <div class="sub">$<%= number_with_delimiter(@student_total_paid) %> de $<%= number_with_delimiter(@student_total_to_pay) %></div>
      </div>
    </div>

    <div class="card">
      <h2>Inscripciones (<%= @student_enrollments.size %>)</h2>
      <% @student_enrollments.each do |enr| %>
        <%
          courses = enr.enrollment_sections.map { |es| es.section.course }.uniq
          regulars = enr.enrollment_sections.select(&:regular?)
          enr_present = regulars.count { |es| es.attended == true }
          enr_total = regulars.size
          enr_rate = enr_total.positive? ? ((enr_present + enr.enrollment_sections.select(&:makeup?).count { |m| m.attended == true }).to_f / enr_total * 100).round : nil
          enr_paid = enr.payments.select { |p| p.status == 'completed' }.sum(&:amount).to_i
          enr_total_pay = enr.enrollment_amount.to_i + enr.total_tuition_fee.to_i
          enr_balance = enr_total_pay - enr_paid
        %>
        <div class="enr-card">
          <div class="enr-card-info">
            <h4>
              <%= link_to "Inscripción ##{enr.id}", admin_enrollment_path(enr), style: "color: #2c3e50; text-decoration: none;" %>
              · <%= courses.map(&:title).join(', ') %>
            </h4>
            <div class="enr-card-meta">
              Plan: <strong><%= enr.weekly_plan.plan %></strong>
              · <%= enr.payment_method.payment_method %>
              · Inscrito <%= I18n.l(enr.created_at.to_date, format: '%d/%m/%Y') %>
              <br>
              Asistencia: <strong><%= enr_rate ? "#{enr_rate}%" : '—' %></strong>
              (<%= enr_present %>/<%= enr_total %>)
              · Saldo:
              <% if enr_balance.positive? %>
                <span class="balance-tag debt">Debe $<%= number_with_delimiter(enr_balance) %></span>
              <% else %>
                <span class="balance-tag clear">Al día</span>
              <% end %>
            </div>
          </div>
          <div class="enr-card-actions">
            <%= link_to "Ver inscripción", admin_enrollment_path(enr), class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card">
      <p style="color: #7f8c8d; text-align: center; padding: 1.5rem;">Este alumno no tiene inscripciones registradas.</p>
    </div>
  <% end %>
<% end %>

<% if @user.teacher && @teacher_sections.present? %>
  <!-- Estadísticas del Docente -->
  <div class="stats-grid">
    <div class="stat-card">
      <h3>Cursos</h3>
      <div class="number"><%= @teacher_courses.count %></div>
    </div>
    <div class="stat-card">
      <h3>Secciones</h3>
      <div class="number"><%= @teacher_sections.count %></div>
    </div>
    <div class="stat-card">
      <h3>Alumnos</h3>
      <div class="number"><%= @teacher_students.count %></div>
    </div>
  </div>

  <!-- Cursos que imparte -->
  <div class="card">
    <h2>Cursos que imparte</h2>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem;">
      <% @teacher_courses.each do |course| %>
        <%= link_to course.title, admin_course_path(course),
            style: "background: #3498db; color: white; padding: 0.5rem 1rem; border-radius: 4px; text-decoration: none;" %>
      <% end %>
    </div>
  </div>

  <!-- Secciones -->
  <div class="card">
    <h2>Secciones</h2>
    <table>
      <thead>
        <tr>
          <th>Curso</th>
          <th>Día</th>
          <th>Horario</th>
          <th>Cupos</th>
          <th>Alumnos</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @teacher_sections.each do |section| %>
          <% students_count = @students_count_by_section[section.id]&.count || 0 %>
          <tr>
            <td><%= section.course.title %></td>
            <td><%= section.weekday %></td>
            <td><%= section.formatted_schedule %></td>
            <td><%= section.places %></td>
            <td><%= students_count %></td>
            <td>
              <%= link_to "Ver", admin_section_path(section), class: "btn btn-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Listado de Alumnos -->
  <div class="card">
    <h2>Alumnos (<%= @teacher_students.count %>)</h2>
    <% if @teacher_students.any? %>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% @teacher_students.each_with_index do |student, index| %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= student.user.name %></td>
              <td><%= student.user.email %></td>
              <td>
                <%= link_to "Ver", admin_user_path(student.user), class: "btn btn-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p style="color: #7f8c8d; font-style: italic;">No tiene alumnos actualmente.</p>
    <% end %>
  </div>
<% end %>
