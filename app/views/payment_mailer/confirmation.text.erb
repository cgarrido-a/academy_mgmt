<% @sections.each do |section| -%>
- <%= section.course.title %>: <%= section.weekday %>, <%= section.formatted_schedule %>
<% end -%>
<% if @class_dates.any? -%>

Fechas de tus clases:
<%= @class_dates.map { |d| l(d, format: '%d/%m/%Y') rescue d.strftime('%d/%m/%Y') }.join(', ') %>
