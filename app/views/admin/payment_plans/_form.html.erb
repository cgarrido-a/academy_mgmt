<%= form_with model: [:admin, payment_plan], local: true do |f| %>
  <% if payment_plan.errors.any? %>
    <div class="alert alert-error">
      <h3><%= pluralize(payment_plan.errors.count, "error") %> impidieron guardar este plan:</h3>
      <ul>
        <% payment_plan.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :plan, "Plan" %>
    <%= f.text_field :plan, required: true, placeholder: "Ej: Plan A, Plan Mensual, Plan Trimestral" %>
    <small style="color: #666;">Nombre o identificador del plan de pago</small>
  </div>

  <div class="form-group">
    <%= f.label :price, "Precio" %>
    <%= f.text_field :price, required: true, placeholder: "Ej: Plan A, Plan Mensual, Plan Trimestral" %>
    <small style="color: #666;">Precio del plan</small>
  </div>


  <div class="form-group">
    <%= f.label :description, "Descripción" %>
    <%= f.text_area :description, required: true, rows: 3, placeholder: "Ej: Plan de pago en 3 cuotas mensuales sin interés" %>
  </div>

  <div class="form-group">
    <%= f.label :number_of_classes, "Número de Clases" %>
    <%= f.number_field :number_of_classes, min: 1, placeholder: "Ej: 12, 24, 36" %>
    <small style="color: #666;">Cantidad de clases incluidas en este plan (opcional)</small>
  </div>

  <div class="actions">
    <%= f.submit "Guardar", class: "btn btn-success" %>
    <%= link_to "Cancelar", admin_payment_plans_path, class: "btn btn-secondary" %>
  </div>
<% end %>
