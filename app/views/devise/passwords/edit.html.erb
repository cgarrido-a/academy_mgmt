<!DOCTYPE html>
<html>
<head>
  <title>Cambiar Contraseña - Gustarte Admin</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background: #f5f5f5;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    /* Card */
    .login-card {
      background: white;
      border-radius: 8px;
      padding: 2.5rem;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      width: 100%;
      max-width: 400px;
      margin: 2rem;
    }

    .login-card h2 {
      margin-bottom: 1rem;
      color: #2c3e50;
      text-align: center;
      font-size: 1.8rem;
    }

    .login-card p {
      margin-bottom: 2rem;
      color: #555;
      text-align: center;
      font-size: 0.9rem;
    }

    .logo {
      text-align: center;
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    /* Form */
    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      color: #2c3e50;
    }

    .form-group input[type="password"] {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 1rem;
    }

    .form-group input:focus {
      outline: none;
      border-color: #3498db;
      box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
    }

    .form-group em {
      display: block;
      margin-top: 0.25rem;
      font-size: 0.85rem;
      color: #777;
    }

    /* Buttons */
    .btn {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      border-radius: 4px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-size: 1rem;
      transition: all 0.2s;
      width: 100%;
      font-weight: 500;
    }

    .btn-primary {
      background: #3498db;
      color: white;
    }

    .btn-primary:hover {
      background: #2980b9;
    }

    /* Links */
    .links {
      margin-top: 1.5rem;
      text-align: center;
      padding-top: 1.5rem;
      border-top: 1px solid #eee;
    }

    .links a {
      color: #3498db;
      text-decoration: none;
      font-size: 0.9rem;
      display: block;
      margin: 0.5rem 0;
    }

    .links a:hover {
      color: #2980b9;
      text-decoration: underline;
    }

    /* Alerts */
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 4px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .alert-error {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
    }

    .alert-notice {
      background: #d1ecf1;
      color: #0c5460;
      border: 1px solid #bee5eb;
    }

    .error-messages {
      background: #f8d7da;
      color: #721c24;
      border: 1px solid #f5c6cb;
      padding: 0.75rem 1rem;
      border-radius: 4px;
      margin-bottom: 1.5rem;
      font-size: 0.9rem;
    }

    .error-messages h2 {
      font-size: 1rem;
      margin-bottom: 0.5rem;
    }

    .error-messages ul {
      margin-left: 1.5rem;
    }
  </style>
</head>

<body>
  <div class="login-card">
    <div class="logo">🎓</div>
    <h2>Cambiar Contraseña</h2>
    <p>Ingresa tu nueva contraseña.</p>

    <% if alert %>
      <div class="alert alert-error"><%= alert %></div>
    <% end %>

    <% if notice %>
      <div class="alert alert-notice"><%= notice %></div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="form-group">
        <%= f.label :password, "Nueva Contraseña" %>
        <% if @minimum_password_length %>
          <em>(<%= @minimum_password_length %> caracteres mínimo)</em>
        <% end %>
        <%= f.password_field :password, autofocus: true, autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirmar Nueva Contraseña" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.submit "Cambiar mi contraseña", class: "btn btn-primary" %>
      </div>
    <% end %>

    <div class="links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</body>
</html>
