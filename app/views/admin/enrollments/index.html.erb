<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h2 style="margin: 0;">Inscripciones <span style="color: #7f8c8d; font-weight: 400; font-size: 0.95rem;">(<%= @enrollments.size %>)</span></h2>
    <%= link_to "Nueva Inscripción", new_admin_enrollment_path, class: "btn btn-success" %>
  </div>

  <%= form_with url: admin_enrollments_path, method: :get, local: true, style: "margin-bottom: 1.25rem;" do |f| %>
    <div style="display: flex; gap: 0.5rem; max-width: 500px;">
      <%= text_field_tag :q, @q, placeholder: 'Buscar por nombre o email del alumno…',
            style: "flex: 1; padding: 0.55rem 0.85rem; border: 1px solid #dee2e6; border-radius: 6px; font-size: 0.95rem;" %>
      <%= submit_tag "Buscar", class: "btn btn-primary" %>
      <% if @q.present? %>
        <%= link_to "Limpiar", admin_enrollments_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>

  <% if @enrollments.any? %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Estudiante</th>
          <th>Curso</th>
          <th>Sección</th>
          <th>Plan de Pago</th>
          <th>Método de Pago</th>
          <th>Monto</th>
          <th>Fecha</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @enrollments.each do |enrollment| %>
          <tr>
            <td>#<%= enrollment.id %></td>
            <td><%= enrollment.student.user.name %></td>
            <td><%= enrollment.sections.map { |s| s.course.title }.uniq.join(', ') %></td>
            <td><%= enrollment.sections.map { |s| s.formatted_schedule }.join(', ') %></td>
            <td><%= enrollment.weekly_plan.description %></td>
            <td><%= enrollment.payment_method.payment_method %></td>
            <td>$<%= number_with_delimiter(enrollment.total_tuition_fee) %></td>
            <td><%= enrollment.created_at.strftime('%d/%m/%Y') %></td>
            <td>
              <div class="actions">
                <%= link_to "Ver", admin_enrollment_path(enrollment), class: "btn btn-primary" %>
                <%= link_to "Editar", edit_admin_enrollment_path(enrollment), class: "btn btn-secondary" %>
                <%= button_to "Eliminar", admin_enrollment_path(enrollment), method: :delete, data: { confirm: "¿Estás seguro?" }, class: "btn btn-danger" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p style="color: #7f8c8d; text-align: center; padding: 2rem;">
      <% if @q.present? %>
        No se encontraron inscripciones para "<%= @q %>".
      <% else %>
        No hay inscripciones registradas.
      <% end %>
    </p>
  <% end %>
</div>
