<div class="card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h2>Plan Semanal #<%= @weekly_plan.id %></h2>
    <div class="actions">
      <%= link_to "Editar", edit_admin_weekly_plan_path(@weekly_plan), class: "btn btn-secondary" %>
      <%= link_to "Volver", admin_weekly_plans_path, class: "btn btn-primary" %>
    </div>
  </div>

  <div class="form-group">
    <strong>Plan:</strong>
    <p><%= @weekly_plan.plan %></p>
  </div>

  <div class="form-group">
    <strong>Clases por Semana:</strong>
    <p><%= @weekly_plan.weekly_classes || 'No especificado' %></p>
  </div>

  <div class="form-group">
    <strong>Precio Mensual:</strong>
    <p>$<%= number_with_delimiter(@weekly_plan.price || 0) %></p>
  </div>

  <div class="form-group">
    <strong>Descripción:</strong>
    <p><%= @weekly_plan.description %></p>
  </div>
</div>

<div class="card">
  <h2>Inscripciones con este Plan (<%= @enrollments.count %>)</h2>

  <% if @enrollments.any? %>
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Estudiante</th>
          <th>Curso</th>
          <th>Monto</th>
          <th>Fecha</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @enrollments.each do |enrollment| %>
          <tr>
            <td>#<%= enrollment.id %></td>
            <td><%= enrollment.student.user.name %></td>
            <td><%= enrollment.sections.map { |s| s.course.title }.uniq.join(', ') %></td>
            <td>$<%= number_with_delimiter(enrollment.enrollment_amount) %></td>
            <td><%= enrollment.created_at.strftime('%d/%m/%Y') %></td>
            <td>
              <%= link_to "Ver", admin_enrollment_path(enrollment), class: "btn btn-primary" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No hay inscripciones con este plan semanal.</p>
  <% end %>
</div>
